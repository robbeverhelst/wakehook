# Secrets are best supplied via env; non-secret tuning can live in config.json.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
# Token Google must present on /webhook (it probes that calls without it get 401).
GOOGLE_WEBHOOK_AUTH_TOKEN=

# Optional overrides
# PORT=8080
# DB_PATH=./wake.sqlite
# CONFIG_PATH=./config.json

# Google ingestion mode — "webhook" (default, needs a public URL) | "poll" (outbound-only) | "both"
# GOOGLE_MODE=poll
# GOOGLE_POLL_INTERVAL_MS=300000          # how often to poll (ms); lower = faster wake, more calls
# GOOGLE_POLL_LOOKBACK_MIN=720
# GOOGLE_POLL_WINDOW_ONLY=true            # only poll around the morning window + stop after firing
# GOOGLE_POLL_WINDOW_MARGIN_MIN=30        # minutes of slack before windowStart / after windowEnd
# GOOGLE_HEALTH_API_BASE=https://health.googleapis.com/v4   # override to point at a local fake in tests
