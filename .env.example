# Secrets are best supplied via env; non-secret tuning can live in config.json.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
# Token Google must present on /webhook (it probes that calls without it get 401).
GOOGLE_WEBHOOK_AUTH_TOKEN=

# Optional overrides
# PORT=8080
# DB_PATH=./wake.sqlite
# CONFIG_PATH=./config.json
